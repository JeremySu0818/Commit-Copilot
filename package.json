{
  "name": "commit-copilot",
  "displayName": "%extension.displayName%",
  "description": "%extension.description%",
  "version": "1.9.0",
  "publisher": "JeremySu0818",
  "icon": "assets/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/JeremySu0818/Commit-Copilot"
  },
  "license": "Unlicense",
  "engines": {
    "vscode": "^1.91.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "commit-copilot.generate",
        "title": "%command.generate.title%",
        "category": "Commit-Copilot",
        "icon": "$(wand)",
        "enablement": "!commit-copilot.isGenerating"
      },
      {
        "command": "commit-copilot.cancelGeneration",
        "title": "%command.cancelGeneration.title%",
        "category": "Commit-Copilot",
        "icon": "$(debug-stop)",
        "enablement": "commit-copilot.isGenerating"
      },
      {
        "command": "commit-copilot.openLanguageSettings",
        "title": "%command.openLanguageSettings.title%",
        "category": "Commit-Copilot",
        "icon": "$(settings-gear)"
      }
    ],
    "menus": {
      "scm/title": [
        {
          "command": "commit-copilot.generate",
          "group": "navigation@10",
          "when": "scmProvider == git && !commit-copilot.isGenerating"
        },
        {
          "command": "commit-copilot.cancelGeneration",
          "group": "navigation@10",
          "when": "scmProvider == git && commit-copilot.isGenerating"
        }
      ],
      "view/title": [
        {
          "command": "commit-copilot.openLanguageSettings",
          "group": "navigation",
          "when": "view == commit-copilot.view && commit-copilot.currentScreen == main"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "commit-copilot-activitybar",
          "title": "%viewsContainer.title%",
          "icon": "assets/icon.svg"
        }
      ]
    },
    "views": {
      "commit-copilot-activitybar": [
        {
          "type": "webview",
          "id": "commit-copilot.view",
          "name": "%view.name%",
          "icon": "assets/icon.svg"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "node scripts/move-locales.mjs && npm run package",
    "package": "npm run check-types && node esbuild.mjs --production",
    "compile": "npm run check-types && node esbuild.mjs",
    "clean": "node scripts/clean-locales.mjs",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.mjs --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "watch:tsc:webview": "tsc --noEmit --watch --project tsconfig.webview.json",
    "check-types": "tsc --noEmit --project tsconfig.json && tsc --noEmit --project tsconfig.webview.json",
    "lint": "eslint src --ext ts,tsx",
    "test:build": "tsc --project tsconfig.test.json",
    "test:unit": "npm run test:build && node --test --test-concurrency=1 out/test/**/*.test.js",
    "test": "npm run test:unit",
    "format": "prettier --write .",
    "check-format": "prettier --check ."
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@google/genai": "^1.48.0",
    "isbinaryfile": "^4.0.10",
    "ollama": "^0.6.3",
    "openai": "^6.33.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "20.x",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/vscode": "1.91.0",
    "esbuild": "^0.27.2",
    "eslint": "^8.41.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.2",
    "typescript": "^5.9.3"
  }
}
